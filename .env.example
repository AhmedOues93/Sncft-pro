# API
API_PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:4173

# Storage driver: "memory" for local/tests, "supabase" for production-like usage
STORAGE_DRIVER=memory

# Supabase (server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_ANON_KEY=replace_with_anon_key_if_needed

# Optional helper for import:all script
API_BASE_URL=http://localhost:3000
CSV_DIR=./data/csv
