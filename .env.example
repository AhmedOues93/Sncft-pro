# API
API_PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:4170,http://127.0.0.1:5175

# Storage
STORAGE_DRIVER=memory
SNCFT_DB_PATH=./data/sncft.db

# Supabase (server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_ANON_KEY=replace_with_anon_key_if_needed

# Admin auth and roles
ADMIN_AUTH_REQUIRED=true
SNCFT_DEV_ADMIN_ROLE=superadmin

# Security limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
CSV_BODY_LIMIT=4mb

# Optional helper for import:all script
API_BASE_URL=http://localhost:3000
CSV_DIR=./data/csv
